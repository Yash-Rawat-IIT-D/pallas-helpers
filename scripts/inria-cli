#!/usr/bin/env bash

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/_inria-layout.sh"

TITLE="INRIA Toolchain"
BACKTITLE="Pallas / EZTrace / OTF2 / Blup"

export NEWT_COLORS='
root=green,black
border=green,black
window=green,black
title=black,green
textbox=green,black
button=black,green
actbutton=black,blue
entry=green,black
checkbox=green,black
actcheckbox=black,blue
compactbutton=green,black
actsellistbox=black,blue
sellistbox=green,black
helpline=black,green
roottext=green,black
'

is_sourced() {
    [[ "${BASH_SOURCE[0]}" != "$0" ]]
}

resolve_env_script() {
    case "${1:-}" in
        otf2-eztrace) printf '%s\n' "${INRIA_SCRIPTS_DIR}/env-otf2-eztrace.sh" ;;
        pallas) printf '%s\n' "${INRIA_SCRIPTS_DIR}/env-pallas.sh" ;;
        pallas-eztrace) printf '%s\n' "${INRIA_SCRIPTS_DIR}/env-pallas-eztrace.sh" ;;
        pallas-base) printf '%s\n' "${INRIA_SCRIPTS_DIR}/env-pallas-base.sh" ;;
        pallas-base-eztrace) printf '%s\n' "${INRIA_SCRIPTS_DIR}/env-pallas-base-eztrace.sh" ;;
        blup) printf '%s\n' "${INRIA_SCRIPTS_DIR}/env-blup.sh" ;;
        *) return 1 ;;
    esac
}

resolve_rebuild_script() {
    case "${1:-}" in
        otf2-eztrace) printf '%s\n' "${INRIA_SCRIPTS_DIR}/rebuild-otf2-eztrace.sh" ;;
        pallas) printf '%s\n' "${INRIA_SCRIPTS_DIR}/rebuild-pallas.sh" ;;
        pallas-eztrace) printf '%s\n' "${INRIA_SCRIPTS_DIR}/rebuild-pallas-eztrace.sh" ;;
        pallas-base) printf '%s\n' "${INRIA_SCRIPTS_DIR}/rebuild-pallas-base.sh" ;;
        pallas-base-eztrace) printf '%s\n' "${INRIA_SCRIPTS_DIR}/rebuild-pallas-base-eztrace.sh" ;;
        blup) printf '%s\n' "${INRIA_SCRIPTS_DIR}/rebuild-blup.sh" ;;
        *) return 1 ;;
    esac
}

resolve_run_script() {
    case "${1:-}" in
        kill-trace-procs) printf '%s\n' "${INRIA_SCRIPTS_DIR}/kill-trace-procs.sh" ;;
        *) return 1 ;;
    esac
}

need_whiptail() {
    if ! command -v whiptail >/dev/null 2>&1; then
        echo "[inria-cli] whiptail is required for the terminal UI." >&2
        return 1
    fi
}

pause_after_command() {
    echo
    read -r -p "[inria-cli] Press Enter to continue..." _
}

run_script_in_terminal() {
    local label="$1"
    local script_path="$2"
    shift 2

    clear
    echo "== ${label} =="
    echo
    bash "${script_path}" "$@"
}

apply_environment() {
    local env_name="$1"
    local script_path="$2"

    if ! is_sourced; then
        echo "[inria-cli] Environment changes must be applied by sourcing this CLI." >&2
        echo "[inria-cli] Use: source ${INRIA_SCRIPTS_DIR}/inria-cli env ${env_name}" >&2
        return 1
    fi

    clear
    echo "== Applying ${env_name} environment =="
    echo
    source "${script_path}"
}

show_message() {
    whiptail \
        --backtitle "${BACKTITLE}" \
        --title "${TITLE}" \
        --msgbox "$1" 14 72
}

choose_rebuild() {
    local choice
    local bmark_setting="OFF"
    choice="$(whiptail \
        --backtitle "${BACKTITLE}" \
        --title "${TITLE}" \
        --menu "Choose a rebuild target:" 18 78 8 \
        "otf2-eztrace" "Rebuild normal OTF2 + EZTrace" \
        "pallas" "Rebuild Pallas" \
        "pallas-eztrace" "Rebuild EZTrace against Pallas" \
        "pallas-base" "Rebuild baseline Pallas" \
        "pallas-base-eztrace" "Rebuild EZTrace against baseline Pallas" \
        "blup" "Rebuild Blup config / venv" \
        3>&1 1>&2 2>&3)" || return 1

    if whiptail \
        --backtitle "${BACKTITLE}" \
        --title "${TITLE}" \
        --yesno "Run rebuild for '${choice}' now?" 10 68; then
        if [[ "${choice}" == "pallas" || "${choice}" == "pallas-base" ]]; then
            if whiptail \
                --backtitle "${BACKTITLE}" \
                --title "${TITLE}" \
                --yesno "Enable BMARK for '${choice}' during this rebuild?" 10 74; then
                bmark_setting="ON"
            fi

            run_script_in_terminal \
                "Rebuild: ${choice} (BMARK=${bmark_setting})" \
                "$(resolve_rebuild_script "${choice}")" \
                "-DBMARK=${bmark_setting}"
        else
            run_script_in_terminal "Rebuild: ${choice}" "$(resolve_rebuild_script "${choice}")"
        fi
        pause_after_command
    fi
}

choose_run() {
    local choice
    choice="$(whiptail \
        --backtitle "${BACKTITLE}" \
        --title "${TITLE}" \
        --menu "Choose a utility script:" 15 72 6 \
        "kill-trace-procs" "Stop trace-related processes" \
        3>&1 1>&2 2>&3)" || return 1

    if whiptail \
        --backtitle "${BACKTITLE}" \
        --title "${TITLE}" \
        --yesno "Run '${choice}' now?" 10 60; then
        run_script_in_terminal "Run: ${choice}" "$(resolve_run_script "${choice}")"
        pause_after_command
    fi
}

show_help() {
    local text
    text=$(
        cat <<EOF
Environments:
  otf2-eztrace   -> normal OTF2 + EZTrace
  pallas         -> local Pallas install
  pallas-eztrace -> EZTrace built against Pallas
  pallas-base    -> baseline Pallas install
  pallas-base-eztrace -> EZTrace built against baseline Pallas
  blup           -> Blup environment / venv

Rebuilds:
  otf2-eztrace
  pallas          (GUI can toggle BMARK)
  pallas-eztrace
  pallas-base     (GUI can toggle BMARK)
  pallas-base-eztrace
  blup

Notes:
  - Environment selection applies changes to the current shell.
  - Source this CLI or expose it through a shell function.
  - Rebuilds and utility scripts run directly in this terminal.
EOF
    )
    show_message "${text}"
}

interactive_menu() {
    need_whiptail || return 1

    while true; do
        local choice
        choice="$(whiptail \
            --backtitle "${BACKTITLE}" \
            --title "${TITLE}" \
            --menu "Choose an action in this shell:" 20 88 10 \
            "otf2-eztrace" "Apply env: normal OTF2 + EZTrace" \
            "pallas" "Apply env: Pallas tools and libraries" \
            "pallas-eztrace" "Apply env: EZTrace backed by Pallas" \
            "pallas-base" "Apply env: baseline Pallas tools and libraries" \
            "pallas-base-eztrace" "Apply env: EZTrace backed by baseline Pallas" \
            "blup" "Apply env: Blup environment and venv" \
            "rebuild" "Run a rebuild helper" \
            "utility" "Run a utility script" \
            "help" "Show available toolchains and helpers" \
            "quit" "Exit launcher" \
            3>&1 1>&2 2>&3)" || break

        case "${choice}" in
            otf2-eztrace|pallas|pallas-eztrace|pallas-base|pallas-base-eztrace|blup)
                apply_environment "${choice}" "$(resolve_env_script "${choice}")" || true
                ;;
            rebuild)
                choose_rebuild || true
                ;;
            utility)
                choose_run || true
                ;;
            help)
                show_help
                ;;
            quit)
                break
                ;;
        esac
    done
}

show_usage() {
    cat <<EOF
Usage:
  source ${INRIA_SCRIPTS_DIR}/inria-cli
  source ${INRIA_SCRIPTS_DIR}/inria-cli menu
  source ${INRIA_SCRIPTS_DIR}/inria-cli env <name>
  ${INRIA_SCRIPTS_DIR}/inria-cli rebuild <name>
  ${INRIA_SCRIPTS_DIR}/inria-cli run <name>

Notes:
  - Running without arguments launches the arrow-key terminal UI.
  - env <name> applies the environment to your current shell.
EOF
}

main() {
    local script_path
    local bmark_setting=""

    if [[ $# -eq 0 ]]; then
        interactive_menu
        return
    fi

    case "${1:-}" in
        menu)
            interactive_menu
            ;;
        env)
            [[ $# -eq 2 ]] || { show_usage; return 1; }
            script_path="$(resolve_env_script "$2")" || {
                echo "[inria-cli] Unknown environment: $2" >&2
                return 1
            }
            apply_environment "$2" "${script_path}"
            ;;
        rebuild)
            [[ $# -ge 2 && $# -le 3 ]] || { show_usage; return 1; }
            script_path="$(resolve_rebuild_script "$2")" || {
                echo "[inria-cli] Unknown rebuild target: $2" >&2
                return 1
            }
            if [[ $# -eq 3 ]]; then
                case "$3" in
                    --benchmark|benchmark|bmark|on)
                        bmark_setting="ON"
                        ;;
                    --no-benchmark|no-benchmark|nobmark|off)
                        bmark_setting="OFF"
                        ;;
                    *)
                        echo "[inria-cli] Unknown rebuild flag: $3" >&2
                        return 1
                        ;;
                esac
            fi

            if [[ "$2" == "pallas" || "$2" == "pallas-base" ]] && [[ -n "${bmark_setting}" ]]; then
                run_script_in_terminal "Rebuild: $2 (BMARK=${bmark_setting})" "${script_path}" "-DBMARK=${bmark_setting}"
            else
                run_script_in_terminal "Rebuild: $2" "${script_path}"
            fi
            ;;
        run)
            [[ $# -eq 2 ]] || { show_usage; return 1; }
            script_path="$(resolve_run_script "$2")" || {
                echo "[inria-cli] Unknown utility target: $2" >&2
                return 1
            }
            run_script_in_terminal "Run: $2" "${script_path}"
            ;;
        help|-h|--help)
            show_usage
            ;;
        *)
            show_usage
            return 1
            ;;
    esac
}

main "$@"
